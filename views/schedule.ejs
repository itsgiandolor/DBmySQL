<!DOCTYPE html>
<html lang="en">
<head>
    <%- include("./partials/head.ejs") %>
</head>
<body>
    
    <%- include("./partials/nav.ejs") %>

    <div class="create-blog">
        <h1>Schedule an Appointment</h1>
        <form action="/appointment/schedule" method="POST">
            <label for="appointment_no">Appointment No:</label>
            <input type="text" id="appointment_no" name="appointment_no" placeholder="AUTO_INCREMENT or Leave Blank">

            <label for="concern">Concern:</label>
            <input type="text" id="concern" name="concern" placeholder="e.g., Fever, Check-up" required>

            <label for="appointment_date">Appointment Date:</label>
            <input type="date" id="appointment_date" name="appointment_date" required>

            <label for="amount_due">Amount Due:</label>
            <input type="number" id="amount_due" name="amount_due" placeholder="e.g., 500" required>

            <label for="contact_no">Contact No:</label>
            <input type="text" id="contact_no" name="contact_no" placeholder="e.g., 09123456789" required>

            <label for="patient">Patient ID:</label>
            <input type="text" id="patient" name="patient" placeholder="Patient ID" required>

            <label for="labResults">Lab Results ID:</label>
            <input type="text" id="labResults" name="labResults" placeholder="Lab Results ID (optional)">

            <button>Schedule</button>
        </form>
    </div>

    <%- include("./partials/footer.ejs") %>
</body>
</html>
